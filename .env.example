# === Existing Vercel Project Quick Start Guide ===
# 1. Install the Vercel CLI `pnpm install -g vercel`
# 2. Run `vercel login` to login to your Vercel account
# 3. Run `vercel link --yes --project <project-name>` to link the project to the project in your Vercel account and pull all variables from the Vercel project

# ┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓
# ┃ Admin Secret: Gate for `/register` and `/api/auth/register/*`                       ┃
# ┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛
ADMIN_SECRET=change-me

# ┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓
# ┃ Auth Cookie Secret: Signs cookie for verification without a KV round-trip           ┃
# ┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛
AUTH_COOKIE_SECRET=change-me

# ┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓
# ┃ Vercel Blob: Auto-provisioned on Vercel Blob integration install                    ┃
# ┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛
BLOB_READ_WRITE_TOKEN=

# ┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓
# ┃ Upstash Redis: Auto-provisioned on Upstash Redis integration install                ┃
# ┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓
# ┃ WebAuthn: Passkey Relying Party configuration                                       ┃
# ┃ - WEBAUTHN_RP_ID: Domain of the site (no protocol)                                  ┃
# ┃ - WEBAUTHN_ORIGIN: The full URL of the site, including protocol and port (if any)   ┃
# ┃ - WEBAUTHN_RP_NAME: A human-readable name shown by the OS during the Passkey prompt ┃
# ┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000
WEBAUTHN_RP_NAME="Henry's Website"
